    "verifiedAt": "2026-05-12",
    "popularityRank": 10,
    "installRate": 0.52,
    "iconUrl": "icons/brave.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#fb542b" },
    "auth": {
      "method": "api-key",
      "providerName": "Brave Search",
      "providerSignupUrl": "https://brave.com/search/api/"
    },
    "toolGroups": [
      { "label": "Web Search", "count": 2 },
      { "label": "News", "count": 1 },
      { "label": "Local", "count": 1 }
    ],
    "setupGuide": { "path": "guides/com.brave-brave-search-mcp.md", "estimatedMinutes": 2, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
