{
  "$schema": "../schema/entry.schema.json",
  "name": "com.wirasm/pipedrive-mcp",
  "title": "Pipedrive",
  "description": "Deals, persons, organizations, and activities in Pipedrive CRM via API token.",
  "version": "0.2.0",
  "websiteUrl": "https://github.com/wirasm/pipedrive-mcp",
  "repository": { "url": "https://github.com/wirasm/pipedrive-mcp", "source": "github" },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "pipedrive-mcp",
      "version": "0.2.0",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "PIPEDRIVE_API_TOKEN", "description": "Personal API token from Pipedrive settings.", "isRequired": true, "isSecret": true },
        { "name": "PIPEDRIVE_COMPANY_DOMAIN", "description": "Your Pipedrive subdomain (e.g. acme for acme.pipedrive.com).", "isRequired": true, "isSecret": false }
      ]
    }
  ],
  "x-wayland": {
    "tier": "worker",
    "categories": ["sales", "crm"],
    "tags": ["pipedrive", "crm", "sales"],
    "maintainerType": "community",
    "license": "MIT",
    "verifiedAt": "2026-05-12",
    "popularityRank": 29,
    "installRate": 0.11,
    "iconUrl": "icons/pipedrive.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#1a1a1a" },
    "auth": {
      "method": "api-key",
      "providerName": "Pipedrive",
      "providerSignupUrl": "https://pipedrive.com"
    },
    "toolGroups": [
      { "label": "Deals", "count": 5 },
      { "label": "Persons", "count": 4 },
      { "label": "Organizations", "count": 3 },
      { "label": "Activities", "count": 3 }
    ],
    "setupGuide": { "path": "guides/com.wirasm-pipedrive-mcp.md", "estimatedMinutes": 2, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
