{
  "$schema": "../schema/entry.schema.json",
  "name": "com.saseq/discord-mcp",
  "title": "Discord",
  "description": "Read channel history, send messages, manage roles, and run guild operations via a Discord bot.",
  "version": "0.4.0",
  "websiteUrl": "https://github.com/SaseQ/discord-mcp",
  "repository": { "url": "https://github.com/SaseQ/discord-mcp", "source": "github" },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "discord-mcp",
      "version": "0.4.0",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "DISCORD_BOT_TOKEN", "description": "Bot token from the Discord Developer Portal.", "isRequired": true, "isSecret": true }
      ]
    }
  ],
  "x-wayland": {
    "tier": "worker",
    "categories": ["communication"],
    "tags": ["discord", "chat", "community"],
    "maintainerType": "community",
    "license": "MIT",
    "verifiedAt": "2026-05-12",
    "popularityRank": 20,
    "installRate": 0.22,
    "iconUrl": "icons/discord.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#5865f2" },
    "auth": {
      "method": "api-key",
      "providerName": "Discord Developer Portal",
      "providerSignupUrl": "https://discord.com/developers/applications"
    },
    "toolGroups": [
      { "label": "Messages", "count": 5 },
      { "label": "Channels", "count": 4 },
      { "label": "Roles", "count": 3 },
      { "label": "Guild", "count": 3 }
    ],
    "setupGuide": { "path": "guides/com.saseq-discord-mcp.md", "estimatedMinutes": 4, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
