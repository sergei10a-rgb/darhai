      "registryType": "npm",
      "identifier": "chrome-devtools-mcp",
      "version": "1.1.1",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": []
    }
  ],
  "x-wayland": {
    "tier": "builder",
    "categories": ["developer", "browser"],
    "tags": ["chrome", "devtools", "lighthouse"],
    "maintainerType": "official",
