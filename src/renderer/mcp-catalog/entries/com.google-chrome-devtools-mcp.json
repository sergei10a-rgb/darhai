    "verifiedAt": "2026-05-12",
    "popularityRank": 45,
    "installRate": 0.18,
    "iconUrl": "icons/chrome.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#4285f4" },
    "auth": { "method": "none" },
    "toolGroups": [
      { "label": "Navigation", "count": 3 },
      { "label": "Console", "count": 3 },
      { "label": "Network", "count": 3 },
      { "label": "Performance", "count": 3 },
      { "label": "Lighthouse", "count": 1 }
    ],
    "setupGuide": { "path": "guides/com.google-chrome-devtools-mcp.md", "estimatedMinutes": 1, "stepCount": 1 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
