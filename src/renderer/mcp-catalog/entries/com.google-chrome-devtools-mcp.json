{
  "$schema": "../schema/entry.schema.json",
  "name": "com.google/chrome-devtools-mcp",
  "title": "Chrome DevTools",
  "description": "Live page inspection, console, network, performance, and Lighthouse audits via Chrome DevTools Protocol.",
  "version": "1.1.1",
  "websiteUrl": "https://developer.chrome.com/docs/devtools/mcp",
  "repository": { "url": "https://github.com/GoogleChromeLabs/chrome-devtools-mcp", "source": "github" },
