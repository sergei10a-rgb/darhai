{
  "$schema": "../schema/entry.schema.json",
  "name": "com.cisco/webex-mcp",
  "title": "Webex",
  "description": "Send messages, schedule meetings, and manage spaces in Cisco Webex.",
  "version": "1.0.0",
  "websiteUrl": "https://developer.webex.com/docs/mcp",
  "repository": { "url": "https://github.com/webex/webex-mcp-server", "source": "github" },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@webex/mcp-server",
      "version": "1.0.0",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "WEBEX_ACCESS_TOKEN", "description": "Personal access token from developer.webex.com.", "isRequired": true, "isSecret": true }
      ]
    }
  ],
  "x-wayland": {
    "tier": "worker",
    "categories": ["communication", "calendar"],
    "tags": ["webex", "cisco", "meetings"],
    "maintainerType": "official",
    "license": "Apache-2.0",
    "verifiedAt": "2026-05-12",
    "popularityRank": 23,
    "installRate": 0.14,
    "iconUrl": "icons/webex.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#00bceb" },
    "auth": {
      "method": "api-key",
      "providerName": "Webex Developer",
      "providerSignupUrl": "https://developer.webex.com"
    },
    "toolGroups": [
      { "label": "Messages", "count": 4 },
      { "label": "Spaces", "count": 4 },
      { "label": "Meetings", "count": 3 }
    ],
    "setupGuide": { "path": "guides/com.cisco-webex-mcp.md", "estimatedMinutes": 2, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
